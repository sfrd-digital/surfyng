# ─── Ambiente ────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
APP_NAME=Surfyng

# CORS — domínio do frontend web (checkout Stripe + deep link redirect)
# Dev: http://localhost:3001   Prod: https://app.surfyng.com.br
CORS_ORIGIN=https://app.surfyng.com.br

# ─── Banco de dados ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://surfyng_user:SENHA@localhost:5432/surfyng_db

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Firebase Admin SDK ───────────────────────────────────────────────────────
# Obter em: Console Firebase → Configurações do projeto → Contas de serviço
FIREBASE_PROJECT_ID=surfyng-app
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@surfyng-app.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── Windguru API ─────────────────────────────────────────────────────────────
# Obter em: windguru.cz → Conta → API (requer plano pago)
WINDGURU_USER=seu_usuario_windguru
WINDGURU_PASS=sua_senha_windguru

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Obter em: dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Obter em: dashboard.stripe.com → Products → Prices (IDs dos preços recorrentes)
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_GLOBAL=price_...
# URLs de redirecionamento pós-checkout
STRIPE_SUCCESS_URL=https://app.surfyng.com.br/assinatura/sucesso
STRIPE_CANCEL_URL=https://app.surfyng.com.br/assinatura/cancelado
STRIPE_PORTAL_RETURN_URL=https://app.surfyng.com.br/perfil
