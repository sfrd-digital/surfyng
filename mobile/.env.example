# API do backend Surfyng
# Dev local: iOS Simulator → http://localhost:3000/api/v1
#            Android Emulator → http://10.0.2.2:3000/api/v1
#            Dispositivo físico → http://<IP-DA-MAQUINA>:3000/api/v1
# Produção: https://api.surfyng.app/api/v1
EXPO_PUBLIC_API_URL=http://localhost:3000/api/v1

# URL da web app (checkout Stripe + retorno de deep link)
EXPO_PUBLIC_WEB_URL=http://localhost:3001

# Firebase (Web SDK — valores públicos do projeto Firebase)
EXPO_PUBLIC_FIREBASE_API_KEY=AIza...
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=surfyng-app.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=surfyng-app
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=surfyng-app.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=1234567890
EXPO_PUBLIC_FIREBASE_APP_ID=1:1234567890:web:abc123

# Google OAuth (IDs do console Firebase)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=xxx.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=xxx.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=xxx.apps.googleusercontent.com

# Google Maps (para MapScreen e geocoding reverso)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=AIza...
