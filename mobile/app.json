{
  "expo": {
    "name": "Surfyng",
    "slug": "surfyng",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "surfyng",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#023246"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "bundleIdentifier": "com.surfyng.app",
      "supportsTablet": false,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "O Surfyng usa sua localização para encontrar as praias mais próximas com as melhores condições de surf agora.",
        "NSLocationAlwaysUsageDescription": "O Surfyng usa sua localização para alertas em segundo plano.",
        "NSCameraUsageDescription": "Para tirar fotos das suas sessões de surf.",
        "NSPhotoLibraryUsageDescription": "Para selecionar fotos das suas sessões de surf.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.surfyng.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#023246"
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-location",
      "expo-camera",
      "expo-image-picker",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#22D3EE"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 34
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2063305d-f115-4f47-af8f-519f75ffb6d6"
      }
    }
  }
}
